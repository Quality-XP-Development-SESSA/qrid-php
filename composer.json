{
  "name": "qrid/codec",
  "description": "Decode and encode MergeID electronic invoice QR codes",
  "type": "library",
  "license": "MIT",
  "keywords": ["qrcode", "qr", "invoice", "mergeid", "codec", "decoder"],
  "homepage": "https://github.com/qxdev/qrid-php",
  "authors": [
    {
      "name": "Valentin Secades Mendez",
      "email": "vsecades@qxdev.com"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "suggest": {
    "chillerlan/php-qrcode": "^5.0 — required for encodeQRId() SVG generation"
  },
  "autoload": {
    "psr-4": {
      "QRId\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "QRId\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
